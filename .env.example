# GitHub Personal Access Token (needs repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repository owner (your username or org)
GITHUB_OWNER=yourusername

# GitHub repository name
GITHUB_REPO=brain

# Branch to use (default: main)
GITHUB_BRANCH=main

# Base path in repo where brain files live (default: brain)
BRAIN_BASE_PATH=brain

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Cache TTL in milliseconds for GitHub file reads (default: 30000)
CACHE_TTL_MS=30000

# Number of retries on SHA conflict during writes (default: 3)
WRITE_RETRIES=3
